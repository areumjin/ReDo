{
  "manifest_version": 3,
  "name": "ReDo Collector",
  "version": "0.1.0",
  "description": "웹에서 레퍼런스를 ReDo에 저장",
  "permissions": ["contextMenus", "activeTab", "storage", "clipboardRead"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon-48.png"
    }
  }
}
